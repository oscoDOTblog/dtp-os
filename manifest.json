{
  "name": "dtp-os",
  "description": "dtp-os — new tab home and browser tools",
  "version": "1.0.0",
  "manifest_version": 3,
  "icons": {
    "48": "assets/48.png",
    "128": "assets/128.png"
  },
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "https://xvbc38vi4h.execute-api.us-east-2.amazonaws.com/*",
    "https://*.amazonaws.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "dtp-os",
    "default_icon": {
      "48": "assets/48.png",
      "128": "assets/128.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "tab_override.html"
  }
}
